{
  "permissions": {
    "allow": [
      "Bash(git init)",
      "Bash(git switch:*)",
      "WebSearch",
      "Bash(git commit *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$j=[Console]::In.ReadToEnd()|ConvertFrom-Json; npx prettier --write --ignore-unknown ($j.tool_input.file_path)",
            "shell": "powershell"
          }
        ]
      }
    ]
  }
}
