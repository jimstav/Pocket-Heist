{
  "permissions": {
    "allow": [
      "Bash(git init)",
      "Bash(git switch:*)",
      "WebSearch",
      "Bash(git commit *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "Write-Output '{\"systemMessage\":\"hello\"}'",
            "shell": "powershell"
          },
          {
            "type": "command",
            "command": "jq . > tool-use.json"
          }
        ]
      }
    ]
  }
}
